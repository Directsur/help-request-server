import getpass
import os
import sys

import pymysql
from passlib.context import CryptContext

DB_HOST     = os.getenv("DB_HOST", "localhost")
DB_PORT     = int(os.getenv("DB_PORT", 3306))
DB_NAME     = os.getenv("DB_NAME", "help_request")
DB_USER     = os.getenv("DB_USER", "helprequest")
DB_PASSWORD = os.getenv("DB_PASSWORD", "")

pwd_context = CryptContext(schemes=["bcrypt"], deprecated="auto")

username = sys.argv[1] if len(sys.argv) > 1 else "admin"
print(f"Resetear contraseña para el usuario '{username}'")

env_pwd = os.getenv("ADMIN_PASSWORD", "")
if env_pwd:
    pwd = env_pwd
    print("Contraseña establecida desde variable de entorno.")
else:
    pwd = getpass.getpass("Nueva contraseña: ")
    pwd2 = getpass.getpass("Repite la contraseña: ")
    if pwd != pwd2:
        print("Error: las contraseñas no coinciden.")
        sys.exit(1)
    if len(pwd) < 8:
        print("Error: la contraseña debe tener al menos 8 caracteres.")
        sys.exit(1)

hashed = pwd_context.hash(pwd)

try:
    conn = pymysql.connect(
        host=DB_HOST, port=DB_PORT, database=DB_NAME,
        user=DB_USER, password=DB_PASSWORD, charset="utf8mb4"
    )
    cursor = conn.cursor()
    cursor.execute(
        "INSERT INTO admin_users (username, password_hash) VALUES (%s, %s) "
        "ON DUPLICATE KEY UPDATE password_hash = %s",
        (username, hashed, hashed)
    )
    conn.commit()
    conn.close()
    print(f"Contraseña de '{username}' actualizada correctamente.")
except pymysql.Error as e:
    print(f"Error de base de datos: {e}")
    sys.exit(1)
